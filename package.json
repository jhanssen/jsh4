{
  "name": "jsh",
  "version": "0.1.0",
  "description": "A POSIX-compatible shell with JavaScript as the extension language",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:ts": "tsc",
    "build:native": "cmake-js compile",
    "build": "npm run build:ts && npm run build:native",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "cmake-js": {
    "runtime": "node",
    "runtimeVersion": "22.0.0",
    "arch": "x64"
  },
  "dependencies": {
    "node-addon-api": "^8.3.1"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "@types/node": "^22.0.0",
    "cmake-js": "^8.0.0",
    "tsx": "^4.19.0"
  }
}
