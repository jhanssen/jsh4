{
  "name": "jsh",
  "version": "0.1.0",
  "description": "A POSIX-compatible shell with JavaScript as the extension language",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./api": "./dist/api/index.js",
    "./share/completions/git": "./dist/share/completions/git.js",
    "./share/completions/npm": "./dist/share/completions/npm.js"
  },
  "engines": {
    "node": ">=22.17.0"
  },
  "scripts": {
    "build:ts": "tsc && tsc -p share/tsconfig.json",
    "build:native": "cmake-js compile",
    "build:schemas": "node --import tsx tools/extract-builtin-schemas.ts",
    "build": "npm run build:ts && npm run build:schemas && npm run build:native",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "cmake-js": {
    "runtime": "node",
    "runtimeVersion": "22.0.0"
  },
  "dependencies": {
    "node-addon-api": "^8.3.1",
    "typescript": "~6.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "cmake-js": "^8.0.0",
    "tsx": "^4.19.0"
  }
}
